nextflowVersion = '>=20.10.0'

trace.enabled = true
report.enabled = true
dag.enabled = true

singularity.enabled = true
singularity.autoMounts = true
singularity.cacheDir = "/home/xiaoouw/singularity-cache/"
singularity.pullTimeout = '1h'

process {
    executor = 'slurm'
    containerOptions = '--bind "/scratch:/scratch" --bind "/nfs:/nfs" --bind "/gpfs:/gpfs"'
    clusterOptions = '--account=scjp1'
    shell = ['/bin/bash', '-ueo', 'pipefail']
}

executor {
    name = 'local'
    cpus = 5
    memory = '32 GB'
}

params.sample_id = null
params.rna_results_dir = null
params.atac_results_dir = null
params.outdir = "results"
